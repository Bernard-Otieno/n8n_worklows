      "parameters": {
        "jsCode": "// Safely fetch the error trigger context\nconst errorData = $('Error Trigger').first().json;\n\nreturn [{\n  json: {\n    channel: \"#ops-alerts\",\n    text: `*Pipeline Failure Alert*\\n• *Node:* ${errorData.lastNodeExecuted}\\n• *Reason:* ${errorData.error?.message || 'Unknown error context'}`\n  }\n}];"
      },
